# Environment variables
# Copy to .env and fill in values

# Registry API
PORT=3001
CORS_ORIGIN=*

# Store backend: 'memory' (default, local dev) | 'blob' (Azure Blob Storage, production)
STORE_BACKEND=memory

# Required when STORE_BACKEND=blob
# AZURE_STORAGE_ACCOUNT_NAME=<your-storage-account-name>
# AZURE_STORAGE_CONTAINER_NAME=<your-container-name>

# Nginx reverse-proxy backend (used by launcher & admin containers)
# Local dev: http://registry-api:3001  |  ACA: http://<registry-api-internal-fqdn>
API_BACKEND_URL=http://registry-api:3001

# Launcher (Vite)
VITE_API_BASE=
VITE_IDLE_TIMEOUT=60

# Admin (Vite)
# VITE_API_BASE=
